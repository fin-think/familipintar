        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUp { 
            from { opacity: 0; transform: translateY(20px); } 
            to { opacity: 1; transform: translateY(0); } 
        }
    </style>
</head>
<body class="min-h-screen bg-gray-50 font-sans text-gray-800 selection:bg-teal-200">

    <!-- HEADER -->
