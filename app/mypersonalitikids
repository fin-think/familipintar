        // 3. STATE PENGURUSAN APP
        // ==========================================================
        let answers = {};
        let finalScores = { E: 0, S: 0, T: 0, J: 0 };
        let resultTypeStr = null;

        // Render Ikon dari CDN
        lucide.createIcons();

        // ==========================================================
        // 4. FUNGSI-FUNGSI UTAMA
        // ==========================================================

        // Memulakan Kuiz (Menyembunyikan Halaman Utama)
        function startQuiz() {
            document.getElementById('screen-home').classList.add('hidden');
            document.getElementById('screen-quiz').classList.remove('hidden');
            
            document.getElementById('progress-container-desktop').classList.remove('opacity-0');
            document.getElementById('progress-container-mobile').classList.remove('hidden');
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
            renderQuizQuestions();
        }

        // Generate HTML untuk senarai soalan
        function renderQuizQuestions() {
            const container = document.getElementById('quiz-questions-container');
            container.innerHTML = '';

            questions.forEach(q => {
                let optionsHtml = '';
                
                likertOptions.forEach(opt => {
                    optionsHtml += `
                        <button 
                            onclick="handleAnswer(${q.id}, ${opt.value})" 
                            id="btn-${q.id}-${opt.value}"
                            class="likert-btn likert-btn-${q.id} rounded-full border-[3px] transition-all duration-200 flex items-center justify-center bg-transparent text-transparent ${opt.size} ${opt.colorClass}"
                            data-active-class="${opt.activeClass}"
                            data-color-class="${opt.colorClass} bg-transparent text-transparent"
                            aria-label="Pilih tahap ${opt.value}">
                            <i data-lucide="check-circle-2" class="w-5 h-5 md:w-6 md:h-6 opacity-0 icon-check"></i>
                        </button>
                    `;
                });

                container.innerHTML += `
                    <div class="bg-white p-6 md:p-10 rounded-3xl shadow-sm border border-gray-100 flex flex-col items-center text-center">
                        <h3 class="text-xl md:text-2xl font-semibold text-gray-800 mb-8 max-w-2xl leading-snug">
                            ${q.text}
                        </h3>
                        <div class="flex flex-col items-center mt-6 w-full">
                            <div class="flex justify-between items-center w-full max-w-2xl px-2 md:px-8 mb-2">
                                <span class="text-emerald-600 font-semibold text-xs md:text-sm uppercase tracking-wider">Setuju</span>
                                <span class="text-indigo-600 font-semibold text-xs md:text-sm uppercase tracking-wider">Tidak Setuju</span>
                            </div>
                            <div class="flex justify-between items-center w-full max-w-2xl px-2 md:px-8 gap-1 md:gap-3">
                                ${optionsHtml}
                            </div>
                        </div>
                    </div>
                `;
            });
            lucide.createIcons(); // render ikon di dalam soalan
        }

        // Mengendali pilihan pengguna
        function handleAnswer(questionId, value) {
            answers[questionId] = value;

            // Reset semua butang untuk soalan ini
            const buttons = document.querySelectorAll(`.likert-btn-${questionId}`);
            buttons.forEach(btn => {
                // Buang class aktif
                const activeClasses = btn.getAttribute('data-active-class').split(' ');
                btn.classList.remove(...activeClasses);
                
                // Tambah class default
                const defaultClasses = btn.getAttribute('data-color-class').split(' ');
                btn.classList.add(...defaultClasses);
                
                // Sembunyikan ikon tick
                btn.querySelector('.icon-check').classList.add('opacity-0');
            });

            // Aktifkan butang yang ditekan
            const selectedBtn = document.getElementById(`btn-${questionId}-${value}`);
            const defaultClasses = selectedBtn.getAttribute('data-color-class').split(' ');
            selectedBtn.classList.remove(...defaultClasses);
            
            const activeClasses = selectedBtn.getAttribute('data-active-class').split(' ');
            selectedBtn.classList.add(...activeClasses);
            selectedBtn.querySelector('.icon-check').classList.remove('opacity-0');

            updateProgress();
        }

        // Kemas kini Progress Bar dan semak jika semua siap
        function updateProgress() {
            const answeredCount = Object.keys(answers).length;
            const percentage = (answeredCount / questions.length) * 100;
            
            document.getElementById('progress-bar-fill').style.width = `${percentage}%`;
            document.getElementById('progress-bar-fill-mobile').style.width = `${percentage}%`;
            document.getElementById('progress-text').innerText = `${Math.round(percentage)}% Selesai`;

            if (answeredCount === questions.length) {
                document.getElementById('btn-submit-quiz').classList.remove('hidden');
                document.getElementById('quiz-status-incomplete').classList.add('hidden');
            } else {
                document.getElementById('btn-submit-quiz').classList.add('hidden');
                document.getElementById('quiz-status-incomplete').classList.remove('hidden');
                document.getElementById('remaining-questions-badge').innerText = `${questions.length - answeredCount} soalan lagi`;
            }
        }

        // Kira Markah Akhir
        function calculateResult() {
            finalScores = { E: 0, S: 0, T: 0, J: 0 };

            questions.forEach(q => {
                const answerValue = answers[q.id];
                if (answerValue !== undefined) {
                    finalScores[q.dimension] += (answerValue * q.direction);
                }
            });

            const typeArr = [
                finalScores.E > 0 ? 'E' : finalScores.E < 0 ? 'I' : 'E',
                finalScores.S > 0 ? 'S' : finalScores.S < 0 ? 'N' : 'S',
                finalScores.T > 0 ? 'T' : finalScores.T < 0 ? 'F' : 'T',
                finalScores.J > 0 ? 'J' : finalScores.J < 0 ? 'P' : 'J'
            ];
            
            resultTypeStr = typeArr.join('');

            // Pindah skrin
            document.getElementById('screen-quiz').classList.add('hidden');
            document.getElementById('progress-container-desktop').classList.add('opacity-0');
            document.getElementById('progress-container-mobile').classList.add('hidden');
            
            renderResultPage();
            
            document.getElementById('screen-results').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Fungsi kira peratusan untuk bar dimensi
        function getPercentage(dimension) {
            const dimensionQuestions = questions.filter(q => q.dimension === dimension).length;
            const maxPossibleScore = dimensionQuestions * 3;
            const score = finalScores[dimension];
            const percentage = ((score + maxPossibleScore) / (maxPossibleScore * 2)) * 100;
            return Math.round(percentage);
        }

        // Menjana HTML untuk bar dimensi
        function buildDimensionBar(labelLeft, labelRight, value, colorClass) {
            return `
                <div>
                    <div class="flex justify-between text-sm font-semibold text-gray-700 mb-2">
                        <span>${labelLeft}</span>
                        <span>${labelRight}</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-3 overflow-hidden flex">
                        <div class="h-full ${colorClass}" style="width: ${value}%"></div>
                        <div class="h-full bg-gray-300" style="width: ${100 - value}%"></div>
                    </div>
                </div>
            `;
        }

        // Paparkan Halaman Keputusan
        function renderResultPage() {
            const profile = personalityTypes[resultTypeStr];
            const container = document.getElementById('screen-results');
            
            // 1. Kad Pengenalan Diri
            let html = `
                <div class="text-center mb-10">
                    <h2 class="text-xl font-medium text-gray-500 uppercase tracking-widest mb-2">Jenis Personaliti Anda Ialah</h2>
                    <div class="text-6xl md:text-7xl font-extrabold text-gray-900 mb-4 tracking-tighter">
                        ${resultTypeStr}
                    </div>
                    <div class="inline-flex items-center justify-center p-6 rounded-full mb-6 ${profile.bgClass}">
                        <i data-lucide="${profile.icon}" class="w-16 h-16 ${profile.colorClass}"></i>
                    </div>
                    <h3 class="text-3xl font-bold text-gray-800 mb-4">"${profile.name}"</h3>
                    <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">${profile.desc}</p>
                </div>
            `;

            // 2. Bar Peratusan Dimensi
            html += `
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 mb-10">
                    <h4 class="text-xl font-bold mb-6 border-b pb-4">Pecahan Dimensi Anda</h4>
                    <div class="space-y-6">
                        ${buildDimensionBar('Ekstrovert (E)', 'Introvert (I)', getPercentage('E'), 'bg-emerald-500')}
                        ${buildDimensionBar('Pemerhati (S)', 'Intuitif (N)', getPercentage('S'), 'bg-blue-500')}
                        ${buildDimensionBar('Pemikir (T)', 'Perasa (F)', getPercentage('T'), 'bg-purple-500')}
                        ${buildDimensionBar('Penilai (J)', 'Pencari (P)', getPercentage('J'), 'bg-yellow-500')}
                    </div>
                    <p class="text-sm text-gray-400 mt-6 italic text-center">*Peratusan ini dikira berdasarkan jawapan tepat anda sebentar tadi.</p>
                </div>
            `;

            // 3. Penjelasan Huruf Kod
            html += `
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 mb-10">
                    <h4 class="text-xl font-bold mb-6 border-b pb-4">Maksud Kod "${resultTypeStr}" Anda</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            `;
            
            resultTypeStr.split('').forEach(letter => {
                html += `
                        <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100 flex gap-4 items-start hover:shadow-md transition-shadow">
                            <div class="w-14 h-14 bg-teal-100 text-teal-600 rounded-full flex items-center justify-center font-black text-2xl shrink-0">
                                ${letter}
                            </div>
                            <div>
                                <h5 class="font-bold text-gray-800">${letterExplanations[letter].title}</h5>
                                <p class="text-sm text-gray-600 mt-1 leading-relaxed">${letterExplanations[letter].desc}</p>
                            </div>
                        </div>
                `;
            });

            html += `</div></div>`;

            // 4. Kesesuaian Pekerjaan / Kerjaya
            html += `
                <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 mb-10">
                    <div class="flex items-center gap-3 mb-6 border-b pb-4">
                        <i data-lucide="briefcase" class="w-6 h-6 text-teal-600"></i>
                        <h4 class="text-xl font-bold">Kesesuaian Pekerjaan (Kerjaya Ideal)</h4>
                    </div>
                    <p class="text-gray-600 mb-6">Berdasarkan profil <strong>${profile.name}</strong> anda, berikut adalah bidang kerjaya yang paling serasi dengan gaya kerja, kekuatan, dan nilai peribadi anda:</p>
                    <div class="space-y-5">
            `;

            profile.careers.forEach(career => {
                html += `
                    <div class="group">
                        <div class="flex justify-between items-end mb-2">
                            <span class="font-semibold text-gray-800 group-hover:text-teal-600 transition-colors">${career.name}</span>
                            <span class="text-sm font-bold text-teal-600 bg-teal-50 px-2 py-1 rounded-md">${career.match}% Padan</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden">
                            <div class="h-full bg-gradient-to-r from-teal-400 to-teal-500 rounded-full transition-all duration-1000 ease-out" style="width: ${career.match}%"></div>
                        </div>
                    </div>
                `;
            });

            html += `
                    </div>
                    <p class="text-sm text-gray-400 mt-6 italic text-center">*Skor ini adalah rujukan panduan sahaja. Minat dan pengalaman peribadi juga memainkan peranan penting.</p>
                </div>
            `;

            // 5. Butang Reset
            html += `
                <div class="flex justify-center">
                    <button onclick="resetQuiz()" class="bg-white border-2 border-gray-200 hover:border-gray-300 text-gray-700 font-bold py-3 px-8 rounded-full transition-all flex items-center gap-2">
                        <i data-lucide="rotate-ccw" class="w-5 h-5"></i> Ambil Ujian Semula
                    </button>
                </div>
            `;

            container.innerHTML = html;
            lucide.createIcons();
        }

        // Reset semua
        function resetQuiz() {
            answers = {};
            finalScores = { E: 0, S: 0, T: 0, J: 0 };
            resultTypeStr = null;
            
            updateProgress();
            
            document.getElementById('screen-results').classList.add('hidden');
            document.getElementById('screen-quiz').classList.add('hidden');
            document.getElementById('progress-container-desktop').classList.add('opacity-0');
            document.getElementById('progress-container-mobile').classList.add('hidden');
            
            document.getElementById('screen-home').classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</body>
</html>
