            ISTP: { name: "Virtuoso", desc: "Pengeksperimen yang berani dan praktikal, pakar dalam semua jenis alatan.", icon: "users", colorClass: "text-yellow-600", bgClass: "bg-yellow-100", careers: [{name: "Jurutera Mekanikal", match: 98}, {name: "Jurutera Perisian", match: 93}, {name: "Detektif / Penyiasat", match: 88}] },
            ISFP: { name: "Pengembara", desc: "Seniman yang fleksibel dan menawan, sentiasa bersedia untuk meneroka dan mengalami sesuatu yang baharu.", icon: "users", colorClass: "text-yellow-600", bgClass: "bg-yellow-100", careers: [{name: "Pereka Fesyen", match: 97}, {name: "Chef Eksekutif", match: 92}, {name: "Jurugambar Profesional", match: 87}] },
            ESTP: { name: "Usahawan", desc: "Orang yang bijak, bertenaga dan sangat tanggap, yang benar-benar menikmati kehidupan di pinggir.", icon: "users", colorClass: "text-yellow-600", bgClass: "bg-yellow-100", careers: [{name: "Pedagang Saham", match: 96}, {name: "Pengurus Sukan", match: 91}, {name: "Usahawan Komersial", match: 88}] },
            ESFP: { name: "Penghibur", desc: "Orang yang spontan, bertenaga dan bersemangat - kehidupan tidak pernah membosankan di sekeliling mereka.", icon: "users", colorClass: "text-yellow-600", bgClass: "bg-yellow-100", careers: [{name: "Pelakon / Penghibur", match: 98}, {name: "Pemandu Pelancong", match: 94}, {name: "Perancang Perkahwinan", match: 89}] }
        };

        const letterExplanations = {
            E: { title: "Ekstrovert (E)", desc: "Mendapat tenaga daripada interaksi sosial dan dunia luar." },
            I: { title: "Introvert (I)", desc: "Mendapat tenaga daripada masa bersendirian dan pemikiran dalaman." },
            S: { title: "Pemerhati (S)", desc: "Berpijak di bumi nyata, fokus kepada fakta dan pengalaman praktikal." },
            N: { title: "Intuitif (N)", desc: "Fokus kepada idea abstrak, makna tersirat dan kemungkinan masa depan." },
            T: { title: "Pemikir (T)", desc: "Mengutamakan logik, objektif dan kecekapan dalam membuat keputusan." },
            F: { title: "Perasa (F)", desc: "Mengutamakan empati, keharmonian dan nilai peribadi dalam keputusan." },
            J: { title: "Penilai (J)", desc: "Sukakan struktur, jadual yang terancang dan ketertiban." },
