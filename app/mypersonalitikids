        <div id="progress-container-mobile" class="h-1 bg-gray-200 w-full md:hidden hidden">
             <div id="progress-bar-fill-mobile" class="h-full bg-teal-500 transition-all duration-500 ease-out" style="width: 0%"></div>
        </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-8 md:py-12 relative overflow-x-hidden">
        
        <!-- ========================================== -->
        <!-- SKRIN 1: HALAMAN UTAMA -->
        <!-- ========================================== -->
        <div id="screen-home" class="flex flex-col items-center text-center slide-up">
            <div class="w-24 h-24 bg-teal-100 text-teal-600 rounded-full flex items-center justify-center mb-6">
                <i data-lucide="sparkles" class="w-12 h-12"></i>
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 tracking-tight">
                Ketahui siapa diri <br/><span class="text-teal-600">awak sebenarnya.</span>
            </h1>
            <p class="text-lg text-gray-600 mb-10 max-w-xl leading-relaxed">
                Jawab soalan dengan jujur (walaupun awak tidak menyukai jawapannya) untuk mendapatkan hasil yang paling tepat mengenai profil personaliti, kekuatan, dan potensi awak.
            </p>
            <button onclick="startQuiz()" class="bg-teal-500 hover:bg-teal-600 text-white font-bold py-4 px-10 rounded-full text-lg shadow-lg hover:shadow-xl transition-all flex items-center justify-center gap-2 transform hover:-translate-y-1">
                Ambil Ujian Sekarang <i data-lucide="arrow-right" class="w-5 h-5"></i>
            </button>
            <p class="mt-6 text-sm text-gray-400">
                Hanya mengambil masa 2 minit • Percuma
            </p>
        </div>

        <!-- ========================================== -->
        <!-- SKRIN 2: KUIZ -->
        <!-- ========================================== -->
        <div id="screen-quiz" class="hidden space-y-12 pb-24 fade-in">
            <div id="quiz-questions-container" class="space-y-12">
                <!-- Soalan akan dijana di sini oleh JavaScript -->
            </div>

            <div class="flex flex-col items-center mt-12 pt-8 border-t border-gray-200">
                <!-- Butang Submit (Awalnya disembunyikan) -->
                <button id="btn-submit-quiz" onclick="calculateResult()" class="hidden bg-teal-500 hover:bg-teal-600 text-white font-bold py-4 px-12 rounded-full text-lg shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 flex items-center gap-2 animate-bounce">
                    Lihat Keputusan Saya <i data-lucide="sparkles" class="w-5 h-5"></i>
                </button>
                
                <!-- Status belum siap -->
                <div id="quiz-status-incomplete" class="text-center block">
                    <p class="text-gray-500 mb-4 font-medium">Sila jawab semua soalan untuk melihat keputusan.</p>
                    <div id="remaining-questions-badge" class="inline-block bg-gray-200 text-gray-500 font-bold py-3 px-8 rounded-full opacity-60 cursor-not-allowed">
                        20 soalan lagi
                    </div>
                </div>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- SKRIN 3: KEPUTUSAN -->
        <!-- ========================================== -->
        <div id="screen-results" class="hidden slide-up">
            <!-- Kandungan Keputusan akan dijana oleh JavaScript -->
        </div>

    </main>

<footer class="mt-8 text-center text-black-400 text-xs">
