        };

        // Skala Jawapan (Likert)
        const likertOptions = [
            { value: 3, size: 'w-14 h-14 md:w-16 md:h-16', colorClass: 'border-emerald-500 hover:bg-emerald-500 hover:text-white', activeClass: 'bg-emerald-500 text-white border-emerald-500' },
            { value: 2, size: 'w-12 h-12 md:w-14 md:h-14', colorClass: 'border-emerald-400 hover:bg-emerald-400 hover:text-white', activeClass: 'bg-emerald-400 text-white border-emerald-400' },
            { value: 1, size: 'w-10 h-10 md:w-12 md:h-12', colorClass: 'border-emerald-300 hover:bg-emerald-300 hover:text-white', activeClass: 'bg-emerald-300 text-white border-emerald-300' },
            { value: 0, size: 'w-8 h-8 md:w-10 md:h-10',  colorClass: 'border-gray-300 hover:bg-gray-400 hover:border-gray-400 hover:text-white', activeClass: 'bg-gray-400 text-white border-gray-400' },
            { value: -1, size: 'w-10 h-10 md:w-12 md:h-12', colorClass: 'border-indigo-300 hover:bg-indigo-300 hover:text-white', activeClass: 'bg-indigo-300 text-white border-indigo-300' },
            { value: -2, size: 'w-12 h-12 md:w-14 md:h-14', colorClass: 'border-indigo-400 hover:bg-indigo-400 hover:text-white', activeClass: 'bg-indigo-400 text-white border-indigo-400' },
